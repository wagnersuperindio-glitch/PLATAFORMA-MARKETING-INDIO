// Plataforma Marketing Índio — Schema Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id               String   @id @default(uuid())
  name             String
  city             String
  neighborhood     String?
  address          String?
  phone            String?
  cnpj             String?  @unique
  instagramHandle  String?
  facebookHandle   String?
  tiktokHandle     String?
  whatsappNumber   String?
  whatsappToken    String?
  metaPageId       String?
  metaAccessToken  String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  campaigns        Campaign[]       @relation("CampaignStores")
  products         Product[]
  competitors      Competitor[]
  broadcasts       WhatsappBroadcast[]
  analytics        Analytics[]
  notifications    Notification[]
  contentRequests  ContentRequest[]

  @@map("stores")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CRIADOR")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])

  campaigns        Campaign[]
  notifications    Notification[]
  contentRequests  ContentRequest[]
  broadcasts       WhatsappBroadcast[]

  @@map("users")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  type        String
  status      String   @default("RASCUNHO")
  channels    String   @default("[]")
  description String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  stores          Store[]         @relation("CampaignStores")
  arts            Art[]
  contentRequests ContentRequest[]

  @@map("campaigns")
}

model Art {
  id           String   @id @default(uuid())
  productsJson String?
  imageUrl     String?
  thumbnailUrl String?
  channel      String
  width        Int?
  height       Int?
  generatedBy  String?
  audioInput   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  templateId  String?
  template    Template? @relation(fields: [templateId], references: [id])

  analytics   Analytics[]

  @@map("arts")
}

model Template {
  id         String   @id @default(uuid())
  name       String
  category   String
  format     String
  imageUrl   String
  previewUrl String?
  layersJson String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  arts       Art[]

  @@map("templates")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Float
  priceOld  Float?
  category  String?
  imageUrl  String?
  sku       String?
  barcode   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  @@map("products")
}

model Competitor {
  id          String   @id @default(uuid())
  name        String
  city        String
  instagram   String?
  facebook    String?
  website     String?
  threatLevel String   @default("MEDIA")
  isMonitored Boolean  @default(false)
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  storeId     String?
  store       Store?   @relation(fields: [storeId], references: [id])

  posts       CompetitorPost[]

  @@map("competitors")
}

model CompetitorPost {
  id            String   @id @default(uuid())
  postUrl       String?
  caption       String?
  imageUrl      String?
  detectedAt    DateTime @default(now())
  hasOffer      Boolean  @default(false)
  category      String?
  priceDetected Float?
  productName   String?
  notified      Boolean  @default(false)
  notifiedAt    DateTime?

  competitorId  String
  competitor    Competitor @relation(fields: [competitorId], references: [id])

  @@map("competitor_posts")
}

model Analytics {
  id          String   @id @default(uuid())
  channel     String
  reach       Int      @default(0)
  impressions Int      @default(0)
  reactions   Int      @default(0)
  clicks      Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  comments    Int      @default(0)
  date        DateTime

  artId       String?
  art         Art?     @relation(fields: [artId], references: [id])
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])

  @@map("analytics")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])

  @@map("notifications")
}

model WhatsappBroadcast {
  id           String   @id @default(uuid())
  title        String
  message      String?
  imageUrl     String?
  contactCount Int      @default(0)
  sentCount    Int      @default(0)
  failedCount  Int      @default(0)
  status       String   @default("PENDENTE")
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])

  @@map("whatsapp_broadcasts")
}

model ContentRequest {
  id           String   @id @default(uuid())
  type         String
  title        String
  description  String?
  products     String?
  audioUrl     String?
  templateId   String?
  channels     String   @default("[]")
  priority     String   @default("NORMAL")
  status       String   @default("PENDENTE")
  resultArtUrl String?
  reviewNotes  String?
  scheduledFor DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeId        String
  store          Store     @relation(fields: [storeId], references: [id])
  requestedById  String
  requestedBy    User      @relation(fields: [requestedById], references: [id])
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id])

  @@map("content_requests")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  type        String
  color       String?
  allDay      Boolean  @default(true)
  storeId     String?
  createdAt   DateTime @default(now())

  @@map("calendar_events")
}

model PublicationLog {
  id        String   @id @default(uuid())
  storeId   String
  channel   String
  postId    String?
  postUrl   String?
  status    String
  errorMsg  String?
  payload   String?
  createdAt DateTime @default(now())

  @@map("publication_logs")
}
