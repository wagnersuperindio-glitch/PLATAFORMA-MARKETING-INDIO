# ── BANCO DE DADOS ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/indio_marketing"

# ── AUTENTICAÇÃO ───────────────────────────────────────────────
JWT_SECRET="sua_chave_jwt_secreta_aqui_min_32_chars"
JWT_EXPIRES_IN="7d"

# ── ANTHROPIC (Claude API) ─────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── OPENAI (Whisper) ───────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── META (Instagram + Facebook + WhatsApp) ─────────────────────
META_APP_ID="seu_app_id"
META_APP_SECRET="seu_app_secret"
META_VERIFY_TOKEN="token_webhook_verificacao"
WHATSAPP_BUSINESS_TOKEN="seu_token_whatsapp"
WHATSAPP_PHONE_ID="seu_phone_number_id"

# ── GOOGLE (Gemini / AI Studio) ───────────────────────────────
GEMINI_API_KEY="sua_chave_gemini"

# ── ARMAZENAMENTO (Cloudflare R2 ou AWS S3) ───────────────────
STORAGE_PROVIDER="r2"  # r2 ou s3
R2_ACCOUNT_ID="seu_account_id"
R2_ACCESS_KEY_ID="sua_access_key"
R2_SECRET_ACCESS_KEY="sua_secret_key"
R2_BUCKET_NAME="indio-marketing-assets"
R2_PUBLIC_URL="https://assets.supermercadosindio.com.br"

# ── REDIS (filas de publicação) ────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── APIFY (monitoramento concorrentes) ────────────────────────
APIFY_TOKEN="seu_token_apify"

# ── SCANNTECH (dados de preço competitivo) ────────────────────
SCANNTECH_API_URL="https://api.scanntech.com"
SCANNTECH_TOKEN="seu_token_scanntech"

# ── APP ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"
